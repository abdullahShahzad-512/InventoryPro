@using Microsoft.AspNetCore.Identity
@model List<IdentityUser>
@{
	ViewData["Title"] = "Manage Users";
    var _userManager = Context.RequestServices.GetService(typeof(UserManager<IdentityUser>)) as UserManager<IdentityUser>;
}
<!-- Main Content -->
<div class="flex-fill p-4 bg-light bg-opacity-50">
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-dark">User Management</h2>
                <p class="text-muted mb-0">Manage application users and roles</p>
            </div>
            <a class="btn btn-primary rounded-3" asp-action="AddUser"><i class="bi bi-plus-lg me-2"></i>Add User</a>
        </div>

        <div class="card rounded-4 shadow-sm border-0 bg-white">

            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">

                            <tr>
                                <th>Name</th>
                                <th>Email</th>

                                <th>Role</th>
                                <th class="text-center">Action</th>
                            </tr>
                        </thead>

                        <tbody>
                        @foreach (var user in Model)
                        {
                                var claims = await _userManager.GetClaimsAsync(user);

                                var Role = claims.Any(c => c.Type == "Role" && c.Value == "Admin")? "Admin": "Staff";
                                
                            <tr>

                                    <td>@Role User</td>
                                    <td>@user.Email</td>
                                    <td>@Role</td>
                                <td>

                                    <div class="d-flex justify-content-center gap-1">
                                            @if (user.LockoutEnd == null || user.LockoutEnd <= DateTimeOffset.Now)
                                            {
                                                <a asp-action="BlockUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-danger" title="Block User">
                                                    <i class="bi bi-person-x"></i> Block
                                                </a>
                                            }
                                            else
                                            {
                                                <a asp-action="UnblockUser" asp-route-id="@user.Id" class="btn btn-sm btn-outline-success" title="Unblock User">
                                                    <i class="bi bi-person-check"></i> Unblock
                                                </a>
                                            }
                                        

                                    </div>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>
