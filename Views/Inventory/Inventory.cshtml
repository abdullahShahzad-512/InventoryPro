@model List<Inventory>
@{
    ViewData["Title"] = "Inventory";
    int currentPage = ViewBag.CurrentPage == null ? 1 : Convert.ToInt32(ViewBag.CurrentPage);
    int pageSize = ViewBag.PageSize == null ? 5 : Convert.ToInt32(ViewBag.PageSize);

    int total = Convert.ToInt32(ViewBag.TotalEntries);

    int start = (currentPage - 1) * pageSize + 1;
    int end = Math.Min(currentPage * pageSize, total);
}

<!-- Main Content -->
<div class="flex-fill p-4 bg-light bg-opacity-50">
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-dark">Products Management</h2>

                <p class="text-muted mb-0">Manage your inventory products</p>
            </div>
            
        </div>

        <div class="card rounded-4 shadow-sm border-0 bg-white">
            <div class="card-body">
                <div class="row g-3 mb-4">
                    <div class="col-md-4">

                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                            <input type="text" class="form-control" placeholder="Search products..." />

                        </div>
                    </div>
                    <div class="col-md-3">

                        <select class="form-select">
                            <option>All Categories</option>
                            <option>-content-</option>

                        </select>
                    </div>

                    <div class="col-md-3">
                        <select class="form-select">
                            <option>All Suppliers</option>

                            <option>-content-</option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <select class="form-select">
                            <option>All Stock</option>

                            <option>Low Stock</option>
                            <option>In Stock</option>
                        </select>
                    </div>

                </div>
                
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">

                            <tr>
                                <th>Product Name</th>
                                <th>Quantity</th>

                                <th>Average Cost</th>
                                <th>Cost Price</th>

                                <th>Sale Price</th>
                                <th>Description</th>
                                <th>Last Updated</th>
                                <th>Barcode</th>

                                @* <th class="text-center">Actions</th> *@
                            </tr>
                        </thead>
                        @if (Model == null || Model.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted">No products found</td>
                            </tr>
                        }
                        else
                        { 
                        <tbody>
                            @foreach(var inv in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">

                                            <div class="bg-light rounded p-2 me-2">
                                                <i class="bi bi-box text-primary" style="font-size: 20px;"></i>
                                            </div>
                                            <span class="fw-bold">@inv.Product.ProductName<span>
                                        </div>
                                    </td>

                                        <td><span class="badge bg-light text-dark">@inv.CurrentQuantity</span></td>
                                    <td class="text-muted">@inv.AverageCost</td>
                                    <td>@inv.Product.CostPrice</td>

                                    <td class="fw-bold">@inv.Product.SalePrice</td>
                                    <td class="text-muted">@inv.Product.Description</td>
                                    <td><span class="badge bg-success">@inv.LastUpdated</span></td>

                                    <td><code>@inv.Product.Barcode</code></td>
                                    @* <td>

                                        <div class="d-flex justify-content-center gap-1">
                                            <a class="btn btn-sm btn-outline-info" title="View" asp-action="ViewProduct">
                                                <i class="bi bi-eye"></i>
                                            </a>

                                            <a class="btn btn-sm btn-outline-primary" title="Edit" asp-action="EditProduct" asp-route-id="@product.Id">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a class="btn btn-sm btn-outline-danger" title="Delete" asp-action="DeleteProduct">
                                                <i class="bi bi-trash"></i>
                                            </a>

                                        </div>
                                    </td> *@
                                </tr>
                            }
                        </tbody>
                        }
                    </table>

                </div>

                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div class="text-muted" id="paginationInfo">
                        Showing @start to @end of <b>@total</b>
                    </div>
                    <nav>
                        <ul class="pagination mb-0" id="paginationControls">

                            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Products" asp-route-page="@(ViewBag.CurrentPage - 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>

                            @{
                                int totalPages = ViewBag.TotalPages;
                                int current = ViewBag.CurrentPage;
                                int startPage = Math.Max(1, current - 2);
                                int endPage = Math.Min(totalPages, current + 2);

                                // Always show first page
                                if (startPage > 1)
                                {
                                    <li class="page-item">
                                        <a class="page-link" asp-action="Inventory" asp-route-page="1">1</a>
                                    </li>
                                    if (startPage > 2)
                                    {
                                        <li class="page-item disabled">
                                            <span class="page-link">...</span>
                                        </li>
                                    }
                                }

                                // Show pages around current page
                                for (int i = startPage; i <= endPage; i++)
                                {
                                    <li class="page-item @(i == current ? "active" : "")">
                                        <a class="page-link" asp-action="Inventory" asp-route-page="@i">@i</a>
                                    </li>
                                }

                                // Always show last page
                                if (endPage < totalPages)
                                {
                                    if (endPage < totalPages - 1)
                                    {
                                        <li class="page-item disabled">
                                            <span class="page-link">...</span>
                                        </li>
                                    }
                                    <li class="page-item">
                                        <a class="page-link" asp-action="Inventory" asp-route-page="@totalPages">@totalPages</a>
                                    </li>
                                }
                            }

                            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Inventory" asp-route-page="@(ViewBag.CurrentPage + 1)">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>

                        </ul>
                    </nav>

                </div>
            </div>
        </div>
    </div>
</div>