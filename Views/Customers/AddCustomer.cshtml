@{
    ViewData["Title"] = "Add Customer";
}
<div class="flex-fill p-4 bg-light bg-opacity-50">
    <div class="container-fluid">

        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card rounded-4 shadow-sm border-0 bg-white">
                    <div class="card-body p-4">
                        <div class="mb-4">
                            <h2 class="fw-bold text-dark text-center">Add New Customer</h2>
                            <p class="text-muted mb-0 text-center">Fill in Customer details and click Save.</p>
                        </div>
                        <form asp-action="AddCustomer" mb-3">
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label fw-semibold">Supplier Name</label>
                                    <input type="text" class="form-control" placeholder="Enter customer name"
                                           required />
                                    <span class="text-danger small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Contact Number</label>
                                    <input type="tel" class="form-control" placeholder="Enter contact number" />
                                    <span class="text-danger small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Email Address</label>
                                    <input type="email" class="form-control"
                                           placeholder="Enter email address" />
                                    <span class="text-danger small"></span>
                                </div>


                                <div class="col-12 d-flex justify-content-end gap-2 mt-4">
                                    <a asp-action="Customers" class="btn btn-outline-secondary rounded-3">
                                        <i class="bi bi-x-lg me-2"></i>Cancel
                                    </a>
                                    <button type="submit" class="btn btn-primary rounded-3">
                                        <i class="bi bi-check-lg me-2"></i>Save Customer
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>