@model List<Customer>
@{
    ViewData["Title"] = "Customers";
}
<link rel="stylesheet" href="~/css/Customer.css" asp-append-version="true" />


<div class="flex-fill p-3 customer-page">
    <div class="container-fluid">
        <!-- Page Header -->
        <div class="page-header">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="page-title">Customers Management</h2>
                    <p class="page-subtitle">Manage and track your customer information</p>
                </div>
                <a class="btn btn-primary-custom" asp-action="AddCustomer">
                    <i class="bi bi-plus-lg me-1"></i>Add New Customer
                </a>
            </div>
        </div>

        <!-- Search and Filter Section -->
        <div class="search-filter-card">
            <div class="row g-2">
                <div class="col-md-10">
                    <div class="search-box">
                        <i class="bi bi-search search-icon"></i>
                        <input type="text" class="form-control" 
                            placeholder="Search customers by name, email, or contact...">
                    </div>
                </div>
                <div class="col-md-2">
                    <button class="btn btn-filter w-100">
                        <i class="bi bi-funnel me-1"></i>Filter
                    </button>
                </div>
            </div>
        </div>

        <!-- Data Table Card -->
        <div class="data-card">
            <div class="table-container">
                <div class="table-responsive">
                    <table class="table custom-table">
                        <thead>
                            <tr>
                                <th>Customer Name</th>
                                <th>Contact</th>
                                <th>Email</th>
                                <th>Purchases</th>
                                <th>Last Visited</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if(Model.Count == 0)
                            {
                                <tr>
                                    <td colspan="5">
                                        <div class="empty-state">
                                            <i class="bi bi-inbox"></i>
                                            <p class="empty-state-text">No customers found. Add your first customer to get started!</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @foreach(var c in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="customer-avatar">
                                                <i class="bi bi-person-fill"></i>
                                            </div>
                                            <span class="customer-name">@c.CustomerName</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="contact-info">
                                            <i class="bi bi-telephone me-1"></i>@c.CustomerPhone
                                        </span>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(c.CustomerEmail))
                                        {
                                            <span class="contact-info">
                                                <i class="bi bi-envelope me-1"></i>@c.CustomerEmail
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted" style="font-size: 12px;">-</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge-purchases">@c.TotalPurchases</span>
                                    </td>
                                    <td>
                                        <span class="date-badge">
                                            <i class="bi bi-calendar-event me-1"></i>@c.LatestVisited.ToString("MMM dd, yyyy hh:mm tt")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Pagination Footer -->
            <div class="pagination-container">
                <div class="pagination-info">
                    Showing 1 to @Model.Count of @Model.Count entries
                </div>
                <nav>
                    <ul class="pagination custom-pagination mb-0">
                        <li class="page-item disabled">
                            <span class="page-link">
                                <i class="bi bi-chevron-left"></i>
                            </span>
                        </li>
                        <li class="page-item active">
                            <span class="page-link">1</span>
                        </li>
                        <li class="page-item">
                            <span class="page-link">
                                <i class="bi bi-chevron-right"></i>
                            </span>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>