@model List<Product>

@if (Model == null || Model.Count == 0)
{
    <tr>
        <td colspan="7" class="text-center text-muted">No products found</td>
    </tr>
}
else
{
    @foreach (var product in Model)
    {
        <tr>
            <td>
                <div class="d-flex align-items-center">
                    <div class="bg-light rounded p-2 me-2">
                        <i class="bi bi-box text-primary" style="font-size: 20px;"></i>
                    </div>
                    <span class="fw-bold">@product.ProductName</span>
                </div>
            </td>
            <td><span class="badge bg-light text-dark">@(product.Category ?? "N/A")</span></td>
            <td class="text-muted">Rs @product.CostPrice.ToString("F2")</td>
            <td class="fw-bold">Rs @product.SalePrice.ToString("F2")</td>
            <td class="py-3"><span class="badge text-muted text-dark px-3 py-2">@(product.Description ?? "N/A")</span></td>
            <td><code>@product.Barcode</code></td>
            <td>
                <div class="d-flex justify-content-center gap-1">
                    <a class="btn btn-sm btn-outline-info" title="View" asp-action="ViewProduct" asp-route-id="@product.Id">
                        <i class="bi bi-eye"></i>
                    </a>
                    <a class="btn btn-sm btn-outline-primary" title="Edit" asp-action="EditProduct" asp-route-id="@product.Id">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <a class="btn btn-sm btn-outline-danger" title="Delete" asp-action="DeleteProduct" asp-route-id="@product.Id">
                        <i class="bi bi-trash"></i>
                    </a>
                </div>
            </td>
        </tr>
    }
}
