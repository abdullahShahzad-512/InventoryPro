@model Supplier
@{
    ViewData["Title"] = "Edit Supplier";
}
<div class="flex-fill p-4 bg-light bg-opacity-50">
    <div class="container-fluid">

        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card rounded-4 shadow-sm border-0 bg-white">
                    <div class="card-body p-4">
                        <div class="mb-4">
                            <h2 class="fw-bold text-dark text-center">Edit Supplier</h2>
                            <p class="text-muted mb-0 text-center">Edit supplier details and click Save.</p>
                        </div>

                        <form asp-action="UpdateSupplier" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                            <div class="row g-3">

                                <div class="col-12">
                                    <label class="form-label fw-semibold">Supplier Name</label>
                                    <input asp-for="SupplierName" class="form-control" placeholder="Enter supplier name"  value="@Model.SupplierName"/>
                                    <span asp-validation-for="SupplierName" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Contact Number</label>
                                    <input asp-for="ContactNumber" class="form-control" placeholder="Enter contact number" value="@Model.ContactNumber" />
                                    <span asp-validation-for="ContactNumber" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Email Address</label>
                                    <input asp-for="Email" class="form-control" placeholder="Enter email address" value="@Model.Email"/>
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>

                                <div class="col-12">
                                    <label class="form-label fw-semibold">Address</label>
                                    <textarea asp-for="Address" class="form-control" rows="3"
                                              placeholder="Enter supplier address" value="@Model.Address"></textarea>
                                    <span asp-validation-for="Address" class="text-danger small"></span>
                                </div>

                                <div class="col-12 d-flex justify-content-end gap-2 mt-4">
                                    <a asp-action="Suppliers" class="btn btn-outline-secondary rounded-3">
                                        <i class="bi bi-x-lg me-2"></i> Cancel
                                    </a>
                                    <button type="submit" class="btn btn-primary rounded-3">
                                        <i class="bi bi-check-lg me-2"></i> Update Supplier
                                    </button>
                                </div>
                            </div>
                        </form>

                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
