@model IEnumerable<IMS.Models.Supplier>

@if (Model != null && Model.Any())
{
    foreach (var supplier in Model)
    {
        <tr>
            <td>
                <div class="d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 rounded-circle p-2 me-3">
                        <i class="bi bi-building text-success" style="font-size: 20px;"></i>
                    </div>
                    <span class="fw-bold text-dark">@supplier.SupplierName</span>
                </div>
            </td>
            <td>@supplier.ContactNumber</td>
            <td>@(supplier.Email != null ? supplier.Email : "-")</td>
            <td>
                <div class="d-flex justify-content-center gap-1">
                    <a class="btn btn-sm btn-outline-info rounded-pill" title="View Products" asp-controller="Suppliers" asp-action="ViewProductsBySupplier" asp-route-id="@supplier.Id" asp-route-name="@supplier.SupplierName">
                        <i class="bi bi-box2"></i>
                    </a>
                </div>
            </td>
            <td>
                <div class="d-flex justify-content-center gap-2">
                    <a class="btn btn-sm btn-outline-success rounded-pill" title="View" asp-controller="Suppliers" asp-action="ViewSupplier" asp-route-id="@supplier.Id">
                        <i class="bi bi-eye"></i>
                    </a>
                    <a class="btn btn-sm btn-outline-primary rounded-pill" title="Edit" asp-controller="Suppliers" asp-action="EditSupplier" asp-route-id="@supplier.Id">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <a class="btn btn-sm btn-outline-danger rounded-pill" title="Delete" asp-controller="Suppliers" asp-action="DeleteSupplier" asp-route-id="@supplier.Id">
                        <i class="bi bi-trash"></i>
                    </a>
                </div>
            </td>
        </tr>
    }
}
else
{
    <tr>
        <td colspan="5" class="text-center text-muted">No suppliers found</td>
    </tr>
}
