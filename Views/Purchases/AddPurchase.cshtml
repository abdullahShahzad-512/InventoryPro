@model Purchase
@{
    ViewData["Title"] = "Add Purchase";
}

<div class="flex-fill p-4 bg-light bg-opacity-50">
    <div class="container-fluid">


        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card rounded-4 shadow-sm border-0 bg-white">

                    <div class="card-body p-4">
                        <div class="mb-4">
                            <h2 class="fw-bold text-dark text-center">Add Purchase</h2>
                            <p class="text-muted mb-0 text-center">Record a new inventory purchase</p>
                        </div>
                        <form asp-action="AddPurchase" method="post">
                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                            <div class="mb-3">
                                <label asp-for="SupplierId" class="form-label fw-semibold">Supplier</label>
                                <select asp-for="SupplierId" class="form-select" id="selectSupplier" required>
                                    <option value="">Select a Supplier</option>
                                </select>
                                <span asp-validation-for="SupplierId" class="text-danger"></span>
                            </div>
                           
                            <div class="row" id="productFields"></div>
                           <div class="row mb-3">
                            <button  type="button" class="col-12 md-12 btn btn-primary rounded-3 mt-4" id="addProductbtn">
                                <i class="bi bi-plus-lg me-2"></i>Add Products
                            </button>
                            </div>
                                <div class="col-md-6 mb-3 totalPaidField" style="display:none">
                                    <label class="form-label fw-semibold">Total Expected Amount</label>
                                    <div class="input-group">
                                        <span class="input-group-text">Rs</span>
                                        <input type="number" class="form-control" id="totalExpectedAmount" placeholder="0.00" readonly/>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-3 totalPaidField" style="display:none">
                                    <label asp-for="TotalPaidAmount" class="form-label fw-semibold">Total Paid Amount</label>
                                    <div class="input-group">
                                        <span class="input-group-text">Rs</span>
                                        <input type="number" asp-for="TotalPaidAmount" class="form-control" id="totalPaidAmount" placeholder="0.00" min="0" step="0.01" required/>
                                    </div>
                                    <span asp-validation-for="TotalPaidAmount" class="text-danger"></span>
                                </div>

                            <div class="col-12">
                                <label class="form-label fw-semibold">Note</label>
                                <textarea asp-for="Notes" class="form-control" rows="3"
                                          placeholder="Enter any description or note"></textarea>
                                <span asp-validation-for="Notes" class="text-danger small"></span>
                            </div>
                            <div class="alert alert-danger d-flex align-items-start my-3" role="alert">
                                <i class="bi bi-exclamation-triangle-fill fs-5 mt-1 me-3"></i>

                                <div>
                                    <h6 class="alert-heading fw-bold mb-1">Note:</h6>

                                    <p class="mb-0">
                                        If <strong>Cost Price</strong> is greater than the existing <strong>Sale Price</strong>, the Sale Price will be updated to match the Cost Price.
                                    </p>
                                </div>
                            </div>

                            <div class="d-flex justify-content-end gap-2 mt-4">
                                <a asp-controller="Purchases"asp-action="Purchases" class="btn btn-outline-secondary rounded-3">
                                    <i class="bi bi-x-lg me-2"></i>Cancel
                                </a>

                                <button type="submit" class="btn btn-primary rounded-3">
                                    <i class="bi bi-check-lg me-2"></i>Save Purchase
                                </button>
                            </div>
                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@* 
@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
} *@