@model List<Sale>

@{
    ViewData["Title"] = "Staff Dashboard";
}



<div class="d-flex">
    

    <!-- Main Content -->
    <div class="flex-fill p-4 bg-light bg-opacity-50">

        <h2 class="fw-bold text-dark">Staff Dashboard</h2>
        <p class="text-muted">Overview of your Sales</p>

        <!-- Cards Row -->
        <div class="row g-4 mb-4">

                   


            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                


                                <th>Date</th>
                                <th>Invoice#</th>
                                <th>Customer</th>
                                <th>Quantity</th>
                                <th>Total Cost</th>
                                <th>View</th>
                            </tr>
                            
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center">No sales records found.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var sale in Model)
                                {
                                    <tr>
                                        <td>@sale.SaleDate</td>
                                        <td>@sale.InvoiceNumber</td>
                                        <td>@sale.Customer.CustomerName</td>
                                        <td>@sale.SaleProducts.Count</td>
                                        <td>@sale.TotalAmount</td>
                                        <td>
                                            <a class="btn btn-sm btn-outline-info action-btn" asp-controller="Sales" asp-action="GetInvoice" asp-route-id="@sale.Id"
                                               title="View">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>

                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>

