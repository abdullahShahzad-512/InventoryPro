﻿@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

<div class="bg-primary bg-opacity-15 border-end border-primary border-opacity-25 shadow-sm d-flex flex-column"
     style="width:260px; height:100%;">
    <div class="p-4 text-white flex-grow-1">

        <a class="brand d-flex align-items-center px-3 text-white text-decoration-none"
           asp-controller="Dashboard" asp-action="Index">
            <i class="bi bi-box-seam me-2" style="font-size:28px;color:#fff"></i>
            <div class="brand-text">
                <h5 class="mb-0">Inventory</h5>
                <small class="small text-white-50">Management</small>
            </div>
        </a>
        <br />
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Dashboard" asp-action="Index" class="d-block text-white text-decoration-none p-2 rounded mb-2 bg-light bg-opacity-10">
                <i class="bi bi-speedometer2 me-2"></i>Dashboard
            </a>
            <a asp-controller="Inventory" asp-action="Inventory"
               class="d-block text-white text-decoration-none p-2 rounded mb-2 bg-light bg-opacity-10">
                <i class="bi bi-box2-fill me-2"></i>Inventory
            </a>
            <a asp-controller="Products" asp-action="Products"
               class="d-block text-white text-decoration-none p-2 rounded mb-2 bg-light bg-opacity-10">
                <i class="bi bi-box me-2"></i>Products
            </a>
            <a asp-controller="Suppliers" asp-action="Suppliers"
               class="d-block text-white text-decoration-none p-2 rounded mb-2 bg-light bg-opacity-10">
                <i class="bi bi-people me-2"></i>Suppliers
            </a>
            <a asp-controller="Customers" asp-action="Customers"
               class="d-block text-white text-decoration-none p-2 rounded mb-2 bg-light bg-opacity-10">
                <i class="bi bi-person-badge me-2"></i>Customers
            </a>
            <a asp-controller="Sales" asp-action="POS"
               class="d-block text-white text-decoration-none p-2 rounded mb-2 bg-light bg-opacity-10">
                <i class="bi bi-cart me-2"></i>POS
            </a>

            <a asp-controller="Sales" asp-action="Sales"
               class="d-block text-white text-decoration-none p-2 rounded mb-2 bg-light bg-opacity-10">
                <i class="bi bi-receipt me-2"></i>Sales
            </a>
            <a asp-controller="Purchases" asp-action="Purchases"
               class="d-block text-white text-decoration-none p-2 rounded mb-2 bg-light bg-opacity-10">
                <i class="bi bi-bag me-2"></i>Purchases
            </a>
            <a asp-controller="Reports" asp-action="Reports"
               class="d-block text-white text-decoration-none p-2 rounded mb-2 bg-light bg-opacity-10">
                <i class="bi bi-bar-chart me-2"></i>Reports
            </a>
            <a asp-controller="Users" asp-action="UserManagement"
               class="d-block text-white text-decoration-none p-2 rounded mb-2 bg-light bg-opacity-10">
                <i class="bi bi-person-gear me-2"></i>User Management
            </a>
        }
        else
        {
            <a asp-controller="Dashboard" asp-action="Index" class="d-block text-white text-decoration-none p-2 rounded mb-2 bg-light bg-opacity-10">
                <i class="bi bi-speedometer2 me-2"></i>Dashboard
            </a>
            <a asp-controller="Sales" asp-action="POS"
               class="d-block text-white text-decoration-none p-2 rounded mb-2 bg-light bg-opacity-10">
                <i class="bi bi-cart me-2"></i>POS
            </a>
        }

        <hr class="border-white border-opacity-50" />

        <a asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Dashboard", new { area = "" })"
           class="d-block text-white text-decoration-none p-2 rounded bg-danger bg-opacity-25">
            <i class="bi bi-box-arrow-left me-2"></i>Logout
        </a>
    </div>
</div>      