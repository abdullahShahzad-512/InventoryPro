@model List<Inventory>
@{
    ViewData["Title"] = "POS";
}

<style>
    .pos-container {
        background: linear-gradient(135deg, #f5f7fa 0%, #e4e8ec 100%);
        min-height: 100vh;
        padding: 2rem 0;
    }

    .page-header {
        margin-bottom: 2rem;
        text-align: center;
    }

        .page-header h2 {
            font-size: 2.5rem;
            font-weight: 700;
            color: #2c3e50;
            margin-bottom: 0.5rem;
            letter-spacing: -0.5px;
        }

        .page-header p {
            color: #7f8c8d;
            font-size: 1rem;
        }

    .product-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07);
        border: none;
        overflow: hidden;
        transition: all 0.3s ease;
    }

        .product-card:hover {
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.12);
            transform: translateY(-2px);
        }

    .cart-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07);
        border: none;
        position: sticky;
        top: 20px;
    }

    .section-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: #2c3e50;
        margin-bottom: 1.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 3px solid #3498db;
        display: inline-block;
    }

    .product-item {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 1rem;
        transition: all 0.2s ease;
        border: 2px solid transparent;
        height: 100%;
    }

        .product-item:hover {
            background: #e9ecef;
            border-color: #3498db;
        }

    .product-name {
        font-size: 1.1rem;
        font-weight: 600;
        color: #2c3e50;
        margin-bottom: 0.5rem;
    }

    .product-category {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 500;
        margin-bottom: 0.5rem;
    }

    .product-description {
        color: #7f8c8d;
        font-size: 0.85rem;
        margin-bottom: 0.75rem;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .product-price {
        font-size: 1.3rem;
        font-weight: 700;
        color: #27ae60;
        margin-top: 0.5rem;
    }

    .add-to-cart-btn {
        background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 0.5rem 1.25rem;
        font-weight: 600;
        transition: all 0.2s ease;
        box-shadow: 0 2px 4px rgba(52, 152, 219, 0.3);
    }

        .add-to-cart-btn:hover {
            background: linear-gradient(135deg, #2980b9 0%, #21618c 100%);
            transform: scale(1.05);
            box-shadow: 0 4px 8px rgba(52, 152, 219, 0.4);
        }

    .cart-header {
        background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
        color: white;
        padding: 1rem;
        margin: -1.25rem -1.25rem 1.5rem -1.25rem;
        border-radius: 16px 16px 0 0;
    }

        .cart-header h5 {
            margin: 0;
            font-size: 1.5rem;
            font-weight: 700;
        }

    .cart-table-header {
        background: #f8f9fa;
        padding: 0.75rem;
        border-radius: 8px;
        margin-bottom: 1rem;
        font-weight: 600;
        color: #2c3e50;
        font-size: 0.85rem;
    }

    .cart-item {
        padding: 0.75rem;
        border-bottom: 1px solid #ecf0f1;
        transition: background 0.2s ease;
    }

        .cart-item:hover {
            background: #f8f9fa;
        }

    .cart-empty {
        text-align: center;
        padding: 2rem 1rem;
        color: #95a5a6;
    }

    .cart-empty-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
        opacity: 0.5;
    }

    .cart-total-section {
        background: #f8f9fa;
        padding: 1rem;
        border-radius: 8px;
        margin-top: 1.5rem;
    }

    .cart-total-label {
        font-size: 1.25rem;
        font-weight: 700;
        color: #2c3e50;
    }

    .cart-total-amount {
        font-size: 1.75rem;
        font-weight: 700;
        color: #27ae60;
    }

    .clear-cart-btn {
        background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 0.75rem;
        font-weight: 600;
        transition: all 0.2s ease;
        box-shadow: 0 2px 4px rgba(231, 76, 60, 0.3);
    }

        .clear-cart-btn:hover {
            background: linear-gradient(135deg, #c0392b 0%, #a93226 100%);
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(231, 76, 60, 0.4);
        }

    .checkout-btn {
        background: linear-gradient(135deg, #27ae60 0%, #229954 100%);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 0.75rem;
        font-weight: 600;
        font-size: 1.1rem;
        transition: all 0.2s ease;
        box-shadow: 0 2px 4px rgba(39, 174, 96, 0.3);
    }

        .checkout-btn:hover {
            background: linear-gradient(135deg, #229954 0%, #1e8449 100%);
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(39, 174, 96, 0.4);
        }

    .empty-products {
        text-align: center;
        padding: 3rem 1rem;
        color: #95a5a6;
    }
</style>

<!-- Main Content -->
<div class="pos-container">
    <div class="container-fluid px-4">
        <div class="page-header">
            <h2>Point of Sale</h2>
            <p>Select products and manage your sales efficiently</p>
        </div>

        <div class="row g-4">
            <!-- Products Section -->
            <div class="col-lg-8">
                <div class="product-card">
                    <div class="card-body p-4">
                        <div class="section-title text-center">Available Products</div>
                        <div class="row g-3 mt-2">
                            @{
                                var hasProducts = false;
                            }
                            @foreach (var ip in Model)
                            {
                                if (ip.CurrentQuantity > 0)
                                {
                                    hasProducts = true;
                                    <div class="col-md-6">
                                        <div class="product-item">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <div class="flex-grow-1">
                                                    <div class="product-name">@ip.Product.ProductName</div>
                                                    <div class="product-category">@ip.Product.Category</div>
                                                    <div class="product-description">@ip.Product.Description</div>
                                                    <div class="product-price">Rs. @ip.Product.SalePrice</div>
                                                </div>
                                                <div class="ms-3">
                                                    <button class="add-to-cart-btn addtocart"
                                                            data-id="@ip.ProductId"
                                                            data-name="@ip.Product.ProductName"
                                                            data-price="@ip.Product.SalePrice">
                                                        <i class="bi bi-plus-circle me-1"></i>Add
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                            @if (!hasProducts)
                            {
                                <div class="col-12">
                                    <div class="empty-products">
                                        <div style="font-size: 3rem; margin-bottom: 1rem;">📦</div>
                                        <h5>No Products Available</h5>
                                        <p>There are currently no products in stock.</p>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Cart Section -->
            <div class="col-lg-4">
                <div class="cart-card">
                    <div class="cart-header">
                        <h5><i class="bi bi-cart3 me-2"></i>Shopping Cart</h5>
                    </div>

                    <div class="card-body">
                        <div class="cart-table-header">
                            <div class="d-flex justify-content-between">
                                <div style="flex: 3; text-align: left;">Product</div>
                                <div style="flex: 1; text-align: center;">Qty</div>
                                <div style="flex: 2; text-align: right;">Price</div>
                            </div>
                        </div>

                        <div id="cartItems">
                            <div class="cart-empty">
                                <div class="cart-empty-icon">🛒</div>
                                <p class="mb-0">Your cart is empty</p>
                                <small>Add products to get started</small>
                            </div>
                        </div>

                        <div class="cart-total-section">
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="cart-total-label">Total:</div>
                                <div id="cartTotal" class="cart-total-amount">Rs. 0.00</div>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-3">
                            <button id="clearCart" class="clear-cart-btn">
                                <i class="bi bi-trash me-2"></i>Clear Cart
                            </button>
                            <button id="checkoutBtn" class="checkout-btn">
                                <i class="bi bi-check-circle me-2"></i>Checkout
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>