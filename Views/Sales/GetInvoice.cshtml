@model Sale
@{

    ViewData["Title"] = "Sale Detail";
    decimal subTotal = 0;

}
<div class="col-lg-12">
    <div class="checkout-card">
        <div class="section-header">
            <i class="bi bi-file-earmark-text"></i>
            Sale Invoice
        </div>
        <div class="card-body p-4">
            <div id="invoiceContent">
                <div class="invoice-header">
                    <h4 class="mb-1">SALES INVOICE</h4>
                    <div class="invoice-number">Invoice #: <span >INV-@Model.InvoiceNumber</span></div>
                    <div class="invoice-date">Date: <span>@Model.SaleDate</span></div>
                    <div class="invoice-date">Sale by: <span>@Model.UserName</span></div>
                    <div class="invoice-date">Customer Name: <span>@Model.Customer.CustomerName</span></div>
                </div>

                <table class="invoice-table">
                    <thead>
                        <tr>
                            <th width="50%">Product</th>
                            <th width="15%" class="text-center">Qty</th>
                            <th width="15%" class="text-end">Price</th>
                            <th width="20%" class="text-end">Total</th>
                        </tr>
                    </thead>
                    <tbody >
                        @foreach(var sp in Model.SaleProducts)
                        {
                            <tr>
                                <td><strong>@sp.ProductName</strong></td>
                                <td class="text-center">@sp.Quantity</td>
                                <td class="text-end">Rs. @sp.UnitPrice</td>
                                <td class="text-end"><strong>Rs.@sp.TotalPrice</strong></td>
                                @{
                                    subTotal += sp.TotalPrice;
                                }
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="invoice-summary">
                    <div class="summary-row">
                        <span>Subtotal:</span>
                        <span">Rs.@subTotal</span>
                    </div>
                    <div class="summary-row">
                        <span>Tax:</span>
                        <span >Rs. @Model.TaxAmount</span>
                    </div>
                    <div class="summary-row">
                        <span>Discount:</span>
                        <span id="tax">Rs. @Model.DiscountAmount</span>
                    </div>
                    <div class="summary-row total">
                        <span>Total Amount:</span>
                        <span id="totalAmount">Rs. @Model.TotalAmount</span>
                    </div>
                </div>
            </div>
        <div class="d-flex justify-content-center gap-2 mb-12 mt-2">
            <button onclick="window.history.back();" class="btn btn-outline-secondary rounded-3">
                <i class="bi bi-box-arrow-left me-2"></i> Back
            </button>

        </div>
        </div>
    </div>
