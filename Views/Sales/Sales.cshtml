@model List<Sale>
@{
    ViewData["Title"] = "Sales";
}
<!-- Main Content -->
<div class="flex-fill p-4 bg-light bg-opacity-50">
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-dark">Sales</h2>

                <p class="text-muted mb-0">Record of inventory Sales</p>
            </div>
        </div>

        <div class="card rounded-4 shadow-sm border-0 bg-white">

            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>

                            <tr>
                                <th>Date</th>
                                <th>Invoice#</th>
                                <th>Customer</th>
                                <th>Staff</th>
                                <th>Quantity</th>
                                <th>Total Cost</th>
                                <th>View</th>

                            </tr>
                        </thead>
                        <tbody>
                            @if(!Model.Any())
                            {
                                <tr>
									<td colspan="6" class="text-center">No sales records found.</td>
								</tr>
                            }
                            else
                            {
                                @foreach(var sale in Model)
                                {
                                    <tr>
                                        <td>@sale.SaleDate</td>
                                        <td>@sale.InvoiceNumber</td>
                                        <td>@sale.Customer.CustomerName</td>
                                        <td>@sale.UserName</td>
                                        <td>@sale.SaleProducts.Count</td>
                                        <td>@sale.TotalAmount</td>
                                        <td>
                                            <a class="btn btn-sm btn-outline-info action-btn" asp-controller="Sales" asp-action="GetInvoice" asp-route-id="@sale.Id"
                                               title="View">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>

                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>