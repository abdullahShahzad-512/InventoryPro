@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
    Layout = "~/Views/Shared/_MinimalLayout.cshtml";
}

    <div class="container-fluid vh-100 d-flex justify-content-center align-items-center ">



        <div class="card rounded-4 shadow-sm w-100" style="max-width: 1000px;">
            <div class="row g-0">

                <div class="col-md-6 d-none d-md-flex align-items-center bg-primary text-white rounded-start-4 bg-opacity-20">
                    <div class="card-body p-5 text-center">

                        <h2 class="fw-bold mb-3">Inventory Management System</h2>
                        <p class="lead mb-4 text-white-50">
                            Manage your stock, suppliers, products, and reports all in one place.
                        </p>

                        <div class="d-flex justify-content-center mb-4">
                            <img width="160" height="120" viewBox="0 0 160 120" src="~/images/logo.svg" role="img"
                                 aria-label="illustration"/>
                                
                        </div>

                        <p class="small mb-0 text-white-50">
                            Need help? <a asp-action="Contact" class="text-white text-decoration-underline">Contact support</a>
                        </p>
                    </div>
                </div>






                <div class="col-12 col-md-6 ">
                    <div class="card-body p-4 p-md-5">

                        <div class="mb-4 text-center">
                            <h3 class="fw-bold mb-1">Sign in to IMS</h3>
                            <p class="text-muted mb-0">Enter your credentials to continue</p>
                        </div>

                    <form   id="account"  method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>


                            <div class="form-floating mb-3">
                                <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="Username/Email" />
                                <label asp-for="Input.Email" class="form-label">Email</label>
                                <span asp-validation-for="Input.Email" class="text-danger"></span>
                            </div>
                            

                            <div class="form-floating mb-3">
                                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                                <label asp-for="Input.Password" class="form-label">Password</label>
                                <span asp-validation-for="Input.Password" class="text-danger"></span>
                            </div>
                            


                     
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <div class="form-check">
                                <label asp-for="Input.RememberMe"  class="form-check-label" >
                                <input class="form-check-input" asp-for="Input.RememberMe" id="remember">
                                @Html.DisplayNameFor(m => m.Input.RememberMe)
                                </label>
                                </div>
                                <a id="forgot-password" asp-page="./ForgotPassword" class="small text-decoration-none">Forgot password?</a>
                            </div>

                            <button id="login-submit" type="submit" class="btn btn-primary w-100 btn-lg mb-3 fw-semibold">
                                Login
                            </button>



                            
                            <div class="text-center">
                                <p class="mb-0 small text-muted">
                                    © 2025 Inventory Management System
                                </p>
                            </div>

                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
