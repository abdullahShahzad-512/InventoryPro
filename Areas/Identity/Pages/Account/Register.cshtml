@page
@model RegisterModel
@{
    ViewData["Title"] = "Add User";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="register-container">
    <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-10 col-md-12">
            <!-- Page Header -->
            <div class="page-header-card card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="header-icon bg-primary bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-person-plus-fill text-primary fs-3"></i>
                        </div>
                        <div>
                            <h2 class="fw-bold text-dark mb-1">Add New User</h2>
                            <p class="text-muted mb-0">
                                Create a new user account with role assignment and credentials
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Registration Form Card -->
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-body p-5">
                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-4" role="alert"></div>

                        <!-- User Information Section -->
                        <div class="form-section mb-4">
                            <h5 class="section-title fw-semibold mb-3">
                                <i class="bi bi-person-circle text-primary me-2"></i>
                                User Information
                            </h5>
                            
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="Input.Email" class="form-label fw-semibold">
                                        <i class="bi bi-envelope me-1"></i>
                                        Email Address
                                    </label>
                                    <input asp-for="Input.Email" 
                                           class="form-control form-control-lg" 
                                           aria-required="true" 
                                           placeholder="user@example.com" />
                                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Input.PhoneNumber" class="form-label fw-semibold">
                                        <i class="bi bi-telephone me-1"></i>
                                        Phone Number
                                    </label>
                                    <input asp-for="Input.PhoneNumber" 
                                           class="form-control form-control-lg" 
                                           aria-required="true" 
                                           placeholder="+92 301 2345678" />
                                    <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Role Assignment Section -->
                        <div class="form-section mb-4">
                            <h5 class="section-title fw-semibold mb-3">
                                <i class="bi bi-shield-check text-primary me-2"></i>
                                Role Assignment
                            </h5>
                            
                            <div class="role-selection">
                                <label asp-for="Input.Role" class="form-label fw-semibold">
                                    User Role
                                </label>
                                <select asp-for="Input.Role" class="form-select form-select-lg" required>
                                    <option value="">Select a role</option>
                                    <option value="Admin">
                                        Administrator - Full system access and management
                                    </option>
                                    <option value="Staff">
                                        Staff - Standard user with limited permissions
                                    </option>
                                </select>
                                <span asp-validation-for="Input.Role" class="text-danger small"></span>
                                
                                <div class="role-info alert alert-info border-0 mt-3">
                                    <i class="bi bi-info-circle me-2"></i>
                                    <strong>Role Permissions:</strong> Admins have full access while Staff users can only access POS and sales features.
                                </div>
                            </div>
                        </div>

                        <!-- Security Section -->
                        <div class="form-section mb-4">
                            <h5 class="section-title fw-semibold mb-3">
                                <i class="bi bi-lock-fill text-primary me-2"></i>
                                Security Credentials
                            </h5>
                            
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="Input.Password" class="form-label fw-semibold">
                                        Password
                                    </label>
                                    <div class="input-group input-group-lg">
                                        <span class="input-group-text bg-light border-end-0">
                                            <i class="bi bi-key"></i>
                                        </span>
                                        <input asp-for="Input.Password" 
                                               type="password"
                                               class="form-control border-start-0" 
                                               autocomplete="new-password" 
                                               aria-required="true" 
                                               placeholder="Enter password" />
                                    </div>
                                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold">
                                        Confirm Password
                                    </label>
                                    <div class="input-group input-group-lg">
                                        <span class="input-group-text bg-light border-end-0">
                                            <i class="bi bi-key-fill"></i>
                                        </span>
                                        <input asp-for="Input.ConfirmPassword" 
                                               type="password"
                                               class="form-control border-start-0" 
                                               autocomplete="new-password" 
                                               aria-required="true" 
                                               placeholder="Re-enter password" />
                                    </div>
                                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="password-requirements card bg-light border-0 mt-3">
                                <div class="card-body p-3">
                                    <h6 class="small fw-semibold mb-2">Password Requirements:</h6>
                                    <ul class="small text-muted mb-0 ps-3">
                                        <li>At least 6 characters long</li>
                                        <li>Include uppercase and lowercase letters</li>
                                        <li>Include at least one number</li>
                                        <li>Include at least one special character</li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="action-buttons d-flex gap-3 justify-content-end pt-4 border-top">
                            <button type="button" 
                                    onclick="window.history.back();" 
                                    class="btn btn-outline-secondary btn-lg px-4">
                                <i class="bi bi-x-lg me-2"></i>
                                Cancel
                            </button>
                            <button id="registerSubmit" 
                                    type="submit" 
                                    class="btn btn-primary btn-lg px-5">
                                <i class="bi bi-check-lg me-2"></i>
                                Create User Account
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Help Card -->
            <div class="help-card card border-0 shadow-sm mt-4">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center gap-3">
                        <div class="help-icon bg-warning bg-opacity-10 rounded-circle p-3">
                            <i class="bi bi-question-circle text-warning fs-4"></i>
                        </div>
                        <div>
                            <h6 class="fw-semibold mb-1">Need Help?</h6>
                            <p class="text-muted small mb-0">
                                Contact system administrator for assistance with user creation and role assignments.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .register-container {
        padding: 20px 0;
        min-height: calc(100vh - 200px);
    }

    .page-header-card {
        border-radius: 12px;
    }

    .header-icon {
        width: 60px;
        height: 60px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .form-section {
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #e5e7eb;
    }

    .form-section:last-of-type {
        border-bottom: none;
    }

    .section-title {
        color: #1e293b;
        font-size: 1.1rem;
    }

    .form-control, .form-select {
        border-radius: 8px;
        border: 1px solid #e5e7eb;
        transition: all 0.3s ease;
    }

    .form-control:focus, .form-select:focus {
        border-color: var(--primary-color);
        box-shadow: 0 0 0 0.25rem rgba(67, 97, 238, 0.1);
    }

    .input-group-text {
        border-radius: 8px 0 0 8px;
    }

    .role-info {
        background: linear-gradient(135deg, rgba(13, 202, 240, 0.1), rgba(13, 202, 240, 0.05));
        border-left: 4px solid #0dcaf0;
    }

    .password-requirements {
        background: linear-gradient(135deg, #f8f9fa, #e9ecef);
    }

    .action-buttons .btn {
        border-radius: 10px;
        font-weight: 500;
        transition: all 0.3s ease;
    }

    .action-buttons .btn-primary {
        background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
        border: none;
        box-shadow: 0 4px 12px rgba(67, 97, 238, 0.25);
    }

    .action-buttons .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(67, 97, 238, 0.35);
    }

    .help-card {
        border-radius: 12px;
    }

    .help-icon {
        width: 55px;
        height: 55px;
    }

    media (max-width: 768px) {
        .action-buttons {
            flex-direction: column;
        }

        .action-buttons .btn {
            width: 100%;
        }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}