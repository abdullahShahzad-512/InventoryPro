@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
    Layout = null;
}
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Access Denied - Inventory Management System</title>
    
    <!-- Core CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/Layout.css">
</head>
<body>
    <div class="app-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <!-- Brand -->
            <div class="sidebar-brand">
                <a class="brand-logo" asp-controller="Dashboard" asp-action="Index">
                    <div class="brand-icon">
                        <i class="bi bi-box-seam"></i>
                    </div>
                    <div class="brand-text">
                        <h4>InventoryPro</h4>
                        <span>Management System</span>
                    </div>
                </a>
            </div>

            <!-- Navigation -->
            <nav class="sidebar-nav">
                <div class="nav-section">
                    <div class="nav-section-title">MAIN</div>
                    <a asp-controller="Dashboard" asp-action="Index" class="nav-link">
                        <i class="bi bi-speedometer2"></i>
                        <span>Dashboard</span>
                    </a>
                </div>

                @if (User.IsInRole("Admin"))
                {
                    <div class="nav-section">
                        <div class="nav-section-title">INVENTORY</div>
                        <a asp-controller="Inventory" asp-action="Inventory" class="nav-link">
                            <i class="bi bi-boxes"></i>
                            <span>Inventory</span>
                        </a>
                        <a asp-controller="Products" asp-action="Products" class="nav-link">
                            <i class="bi bi-box"></i>
                            <span>Products</span>
                        </a>
                    </div>

                    <div class="nav-section">
                        <div class="nav-section-title">PARTNERS</div>
                        <a asp-controller="Suppliers" asp-action="Suppliers" class="nav-link">
                            <i class="bi bi-truck"></i>
                            <span>Suppliers</span>
                        </a>
                        <a asp-controller="Customers" asp-action="Customers" class="nav-link">
                            <i class="bi bi-people"></i>
                            <span>Customers</span>
                        </a>
                    </div>

                    <div class="nav-section">
                        <div class="nav-section-title">TRANSACTIONS</div>
                        <a asp-controller="Sales" asp-action="POS" class="nav-link">
                            <i class="bi bi-cart"></i>
                            <span>POS System</span>
                        </a>
                        <a asp-controller="Sales" asp-action="Sales" class="nav-link">
                            <i class="bi bi-receipt"></i>
                            <span>Sales</span>
                        </a>
                        <a asp-controller="Purchases" asp-action="Purchases" class="nav-link">
                            <i class="bi bi-bag"></i>
                            <span>Purchases</span>
                        </a>
                    </div>

                    <div class="nav-section">
                        <div class="nav-section-title">REPORTS & ADMIN</div>
                        <a asp-controller="Reports" asp-action="Reports" class="nav-link">
                            <i class="bi bi-bar-chart"></i>
                            <span>Reports & Analytics</span>
                        </a>
                        <a asp-controller="Users" asp-action="UserManagement" class="nav-link">
                            <i class="bi bi-person-gear"></i>
                            <span>User Management</span>
                        </a>
                    </div>
                }
                else
                {
                    <div class="nav-section">
                        <div class="nav-section-title">SALES</div>
                        <a asp-controller="Sales" asp-action="POS" class="nav-link">
                            <i class="bi bi-cart"></i>
                            <span>POS System</span>
                        </a>
                    </div>
                }

                <!-- Logout Button -->
                <a asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Dashboard", new { area = "" })"
                   class="logout-btn">
                    <i class="bi bi-box-arrow-left"></i>
                    <span>Logout</span>
                </a>
            </nav>
        </aside>

        <!-- Main Content -->
        <div class="main-content">
            <!-- Top Header -->
            <header class="top-header">
                <div class="header-left">
                    <button class="menu-toggle" id="menuToggle">
                        <i class="bi bi-list"></i>
                    </button>
                    <div class="page-title">
                        <h1>Access Denied</h1>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Home</a></li>
                                <li class="breadcrumb-item active" aria-current="page">Access Denied</li>
                            </ol>
                        </nav>
                    </div>
                </div>

                <div class="user-profile">
                    <div class="user-avatar">
                        <a style="text-decoration: inherit;color: inherit;" asp-area="Identity" asp-page="/Account/Manage/Index">
                            @User.Identity?.Name?.Substring(0, 1).ToUpper()
                        </a>
                    </div>
                    <div class="user-info">
                        <div class="user-name">@User.Identity?.Name?.Split('@')[0]</div>
                        <div class="user-role">
                            @if (User.IsInRole("Admin"))
                            {
                                <span class="status-badge badge-admin">
                                    <i class="bi bi-shield-check"></i> Administrator
                                </span>
                            }
                            else
                            {
                                <span class="status-badge badge-user">
                                    <i class="bi bi-person"></i> Sales Agent
                                </span>
                            }
                        </div>
                    </div>
                </div>
            </header>

            <!-- Content Area -->
            <div class="content-wrapper fade-in">
                <div class="access-denied-container">
                    <div class="row justify-content-center">
                        <div class="col-xl-8 col-lg-10 col-md-12">
                            <div class="error-card card border-0 shadow-lg">
                                <div class="card-body p-5 text-center">
                                    <!-- Error Illustration -->
                                    <div class="error-illustration mb-4">
                                        <div class="error-icon-wrapper">
                                            <i class="bi bi-shield-lock error-icon"></i>
                                            <div class="error-shield-effect"></div>
                                        </div>
                                    </div>

                                    <!-- Error Message -->
                                    <div class="error-content mb-4">
                                        <div class="d-flex align-items-center justify-content-center gap-3 mb-3">
                                            <h1 class="error-title fw-bold mb-0">Access Restricted</h1>
                                            <span class="error-badge badge bg-danger">403</span>
                                        </div>

                                        <p class="error-description text-muted mb-4 px-lg-5">
                                            Sorry, you don't have the necessary permissions to access this resource. 
                                            This area is restricted to authorized personnel only.
                                        </p>

                                        <!-- User Info Card -->
                                        <div class="user-info-card bg-light rounded-3 p-4 mb-4 mx-auto" style="max-width: 500px;">
                                            <div class="d-flex align-items-center justify-content-center gap-3 mb-3">
                                                <div class="user-badge-large bg-primary bg-opacity-10 rounded-circle p-3">
                                                    <i class="bi bi-person fs-4 text-primary"></i>
                                                </div>
                                                <div class="text-start">
                                                    <h6 class="mb-1 fw-semibold text-dark">Current User</h6>
                                                    <p class="mb-0 text-muted">@User.Identity?.Name</p>
                                                </div>
                                            </div>

                                            <div class="role-requirements bg-white rounded-3 p-3 border">
                                                <h6 class="mb-3 fw-semibold text-dark">
                                                    <i class="bi bi-info-circle text-primary me-2"></i>
                                                    Permission Requirements
                                                </h6>
                                                <div class="d-flex flex-wrap gap-2 justify-content-center">
                                                    <span class="badge bg-danger bg-opacity-10 text-danger px-3 py-2">
                                                        <i class="bi bi-shield-check me-1"></i>
                                                        Administrator Access
                                                    </span>
                                                    <span class="badge bg-warning bg-opacity-10 text-warning px-3 py-2">
                                                        <i class="bi bi-key me-1"></i>
                                                        Elevated Privileges
                                                    </span>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Help Text -->
                                        <div class="help-text alert alert-info border-0 mx-auto" style="max-width: 600px;">
                                            <i class="bi bi-lightbulb me-2"></i>
                                            <strong>Need Access?</strong> Contact your system administrator to request the necessary permissions for this resource.
                                        </div>
                                    </div>

                                    <!-- Action Buttons -->
                                    <div class="action-buttons d-flex flex-column flex-sm-row gap-3 justify-content-center pt-3">
                                        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary btn-lg px-4 py-3">
                                            <i class="bi bi-house-door me-2"></i>
                                            Return to Dashboard
                                        </a>

                                        <a href="javascript:history.back()" class="btn btn-outline-secondary btn-lg px-4 py-3">
                                            <i class="bi bi-arrow-left me-2"></i>
                                            Go Back
                                        </a>
                                    </div>

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <div class="mt-4">
                                            <a asp-controller="Users" asp-action="UserManagement" class="btn btn-outline-primary px-4 py-2">
                                                <i class="bi bi-person-gear me-2"></i>
                                                Manage User Permissions
                                            </a>
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- Additional Help Section -->
                            <div class="help-section row g-3 mt-4">
                                <div class="col-md-4">
                                    <div class="help-card card border-0 shadow-sm h-100">
                                        <div class="card-body text-center p-4">
                                            <div class="help-icon bg-primary bg-opacity-10 rounded-circle p-3 d-inline-flex mb-3">
                                                <i class="bi bi-question-circle text-primary fs-4"></i>
                                            </div>
                                            <h6 class="fw-semibold mb-2">Need Help?</h6>
                                            <p class="text-muted small mb-0">Contact support for assistance</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="help-card card border-0 shadow-sm h-100">
                                        <div class="card-body text-center p-4">
                                            <div class="help-icon bg-success bg-opacity-10 rounded-circle p-3 d-inline-flex mb-3">
                                                <i class="bi bi-book text-success fs-4"></i>
                                            </div>
                                            <h6 class="fw-semibold mb-2">Documentation</h6>
                                            <p class="text-muted small mb-0">Learn about user roles</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="help-card card border-0 shadow-sm h-100">
                                        <div class="card-body text-center p-4">
                                            <div class="help-icon bg-info bg-opacity-10 rounded-circle p-3 d-inline-flex mb-3">
                                                <i class="bi bi-envelope text-info fs-4"></i>
                                            </div>
                                            <h6 class="fw-semibold mb-2">Request Access</h6>
                                            <p class="text-muted small mb-0">Submit an access request</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        .access-denied-container {
            padding: 40px 0;
            min-height: calc(100vh - 200px);
        }

        .error-card {
            border-radius: 16px;
            overflow: hidden;
        }

        .error-illustration {
            position: relative;
            margin-bottom: 2rem;
        }

        .error-icon-wrapper {
            position: relative;
            display: inline-block;
        }

        .error-icon {
            font-size: 5rem;
            color: var(--primary-color);
            filter: drop-shadow(0 4px 12px rgba(67, 97, 238, 0.2));
            position: relative;
            z-index: 2;
            animation: pulse 2s infinite;
        }

        .error-shield-effect {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 100px;
            height: 100px;
            background: linear-gradient(135deg, rgba(67, 97, 238, 0.1), rgba(67, 97, 238, 0.05));
            border-radius: 50%;
            animation: ripple 3s infinite;
            z-index: 1;
        }

        .error-title {
            font-size: 2.5rem;
            color: #1e293b;
        }

        .error-badge {
            font-size: 1.25rem;
            padding: 8px 16px;
            border-radius: 12px;
            font-weight: 600;
        }

        .error-description {
            font-size: 1.1rem;
            line-height: 1.6;
            color: #64748b;
        }

        .user-badge-large {
            width: 60px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .user-info-card {
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        }

        .role-requirements {
            background: linear-gradient(135deg, #ffffff, #f8fafc);
        }

        .help-text {
            background: linear-gradient(135deg, rgba(13, 202, 240, 0.1), rgba(13, 202, 240, 0.05));
            border-left: 4px solid #0dcaf0;
        }

        .action-buttons .btn {
            border-radius: 12px;
            font-weight: 500;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .action-buttons .btn-primary {
            background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
            border: none;
            box-shadow: 0 4px 12px rgba(67, 97, 238, 0.25);
        }

        .action-buttons .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(67, 97, 238, 0.35);
        }

        .action-buttons .btn-outline-secondary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(100, 116, 139, 0.15);
        }

        .help-card {
            border-radius: 12px;
            transition: all 0.3s ease;
        }

        .help-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1) !important;
        }

        .help-icon {
            width: 60px;
            height: 60px;
        }

        /* Animations */
       keyframes pulse {
            0%, 100% {
                transform: scale(1);
                opacity: 1;
            }
            50% {
                transform: scale(1.05);
                opacity: 0.9;
            }
        }

        keyframes ripple {
            0% {
                width: 100px;
                height: 100px;
                opacity: 0.3;
            }
            100% {
                width: 160px;
                height: 160px;
                opacity: 0;
            }
        }

        keyframes ripple-animation {
            to {
                transform: scale(4);
                opacity: 0;
            }
        }

        /* Responsive Design */
        media (max-width: 768px) {
            .error-icon {
                font-size: 3.5rem;
            }

            .error-title {
                font-size: 1.75rem;
            }

            .error-badge {
                font-size: 1rem;
                padding: 6px 12px;
            }

            .action-buttons {
                flex-direction: column;
            }

            .action-buttons .btn {
                width: 100%;
            }
        }
    </style>

    <!-- Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // Mobile menu toggle
        document.getElementById('menuToggle').addEventListener('click', function() {
            document.querySelector('.sidebar').classList.toggle('active');
        });

        // Close sidebar when clicking outside on mobile
        document.addEventListener('click', function(event) {
            const sidebar = document.querySelector('.sidebar');
            const menuToggle = document.getElementById('menuToggle');
            
            if (window.innerWidth <= 992 && 
                !sidebar.contains(event.target) && 
                !menuToggle.contains(event.target)) {
                sidebar.classList.remove('active');
            }
        });

        // Interactive effects
        document.addEventListener('DOMContentLoaded', function () {
            // Add click effect to buttons
            const buttons = document.querySelectorAll('.action-buttons .btn');
            buttons.forEach(button => {
                button.addEventListener('click', function (e) {
                    const ripple = document.createElement('span');
                    const rect = this.getBoundingClientRect();
                    const size = Math.max(rect.width, rect.height);
                    const x = e.clientX - rect.left - size / 2;
                    const y = e.clientY - rect.top - size / 2;

                    ripple.style.cssText = `
                        position: absolute;
                        border-radius: 50%;
                        background: rgba(255, 255, 255, 0.6);
                        transform: scale(0);
                        animation: ripple-animation 0.6s linear;
                        width: ${size}px;
                        height: ${size}px;
                        top: ${y}px;
                        left: ${x}px;
                        pointer-events: none;
                    `;

                    this.appendChild(ripple);
                    setTimeout(() => ripple.remove(), 600);
                });
            });

            // Keyboard navigation
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') {
                    history.back();
                }
            });

            // Animate cards on load
            const cards = document.querySelectorAll('.help-card');
            cards.forEach((card, index) => {
                card.style.animation = `fadeIn 0.5s ease-out ${index * 0.1}s both`;
            });
        });
    </script>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>