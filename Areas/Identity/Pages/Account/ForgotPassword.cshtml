@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_MinimalLayout.cshtml";
}

<div class="forgot-password-container">
    <div class="row justify-content-center">
        <div class="col-xl-5 col-lg-6 col-md-8 col-sm-10">
            <!-- Illustration Card -->
            <div class="illustration-card text-center mb-4">
                <div class="forgot-icon-wrapper">
                    <div class="forgot-icon bg-primary bg-opacity-10 rounded-circle p-4 d-inline-flex">
                        <i class="bi bi-key text-primary" style="font-size: 4rem;"></i>
                    </div>
                    <div class="icon-effect"></div>
                </div>
            </div>

            <!-- Main Card -->
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <h1 class="fw-bold mb-2">Forgot Your Password?</h1>
                        <p class="text-muted">
                            No worries! Enter your email address and we'll send you instructions to reset your password.
                        </p>
                    </div>

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 mb-4" role="alert"></div>
                        
                        <div class="mb-4">
                            <label asp-for="Input.Email" class="form-label fw-semibold">
                                <i class="bi bi-envelope me-2"></i>
                                Email Address
                            </label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text bg-light border-end-0">
                                    <i class="bi bi-at"></i>
                                </span>
                                <input asp-for="Input.Email" 
                                       class="form-control border-start-0" 
                                       autocomplete="username" 
                                       aria-required="true" 
                                       placeholder="Enter your email address" />
                            </div>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="info-box alert alert-info border-0 mb-4">
                            <i class="bi bi-info-circle me-2"></i>
                            <strong>How it works:</strong> We'll send a password reset link to your email. Click the link to create a new password.
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 mb-3">
                            <i class="bi bi-envelope-check me-2"></i>
                            Send Reset Instructions
                        </button>

                        <div class="text-center">
                            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-link text-decoration-none">
                                <i class="bi bi-arrow-left me-1"></i>
                                Back to Login
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Help Section -->
            <div class="help-section card border-0 shadow-sm mt-4">
                <div class="card-body p-4">
                    <div class="row g-3 text-center">
                        <div class="col-md-6">
                            <div class="help-item">
                                <i class="bi bi-shield-check text-success fs-3 mb-2"></i>
                                <h6 class="fw-semibold mb-1">Secure Process</h6>
                                <p class="text-muted small mb-0">Your data is encrypted and protected</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="help-item">
                                <i class="bi bi-clock-history text-primary fs-3 mb-2"></i>
                                <h6 class="fw-semibold mb-1">Quick Recovery</h6>
                                <p class="text-muted small mb-0">Reset link valid for 24 hours</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact Support -->
            <div class="text-center mt-4">
                <p class="text-muted small mb-2">Still having trouble?</p>
                <a href="#" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-headset me-1"></i>
                    Contact Support
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .forgot-password-container {
        padding: 40px 0;
        min-height: calc(100vh - 200px);
    }

    .illustration-card {
        position: relative;
        margin-bottom: 2rem;
    }

    .forgot-icon-wrapper {
        position: relative;
        display: inline-block;
    }

    .forgot-icon {
        position: relative;
        z-index: 2;
        animation: float 3s ease-in-out infinite;
    }

    .icon-effect {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 150px;
        height: 150px;
        background: radial-gradient(circle, rgba(67, 97, 238, 0.1), transparent);
        border-radius: 50%;
        animation: pulse-effect 2s ease-in-out infinite;
        z-index: 1;
    }

    .card {
        border-radius: 16px;
    }

    .input-group-text {
        border-radius: 8px 0 0 8px;
        background: linear-gradient(135deg, #f8f9fa, #e9ecef);
    }

    .form-control {
        border-radius: 0 8px 8px 0;
        border: 1px solid #e5e7eb;
        transition: all 0.3s ease;
    }

    .form-control:focus {
        border-color: var(--primary-color);
        box-shadow: 0 0 0 0.25rem rgba(67, 97, 238, 0.1);
    }

    .info-box {
        background: linear-gradient(135deg, rgba(13, 202, 240, 0.1), rgba(13, 202, 240, 0.05));
        border-left: 4px solid #0dcaf0;
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
        border: none;
        border-radius: 10px;
        font-weight: 500;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(67, 97, 238, 0.25);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(67, 97, 238, 0.35);
    }

    .help-section {
        border-radius: 12px;
    }

    .help-item {
        padding: 1rem;
        transition: all 0.3s ease;
    }

    .help-item:hover {
        transform: translateY(-4px);
    }

    /* Animations */
    keyframes float {
        0%, 100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-10px);
        }
    }

    keyframes pulse-effect {
        0%, 100% {
            transform: translate(-50%, -50%) scale(1);
            opacity: 0.3;
        }
        50% {
            transform: translate(-50%, -50%) scale(1.1);
            opacity: 0.1;
        }
    }

    media (max-width: 768px) {
        .forgot-password-container {
            padding: 20px 0;
        }

        .card-body {
            padding: 2rem !important;
        }
    }
</style>

